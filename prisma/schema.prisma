generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}

model GridCell {
  id        String   @id // H3 index
  geom      Unsupported("geometry(Polygon, 4326)")?
  score     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      EnvironmentalDataLog[]
}

model EnvironmentalDataLog {
  id         Int      @id @default(autoincrement())
  gridCellId String
  aqi        Float?
  temperature Float?
  windSpeed  Float?
  windDirection Float?
  score      Float?
  createdAt  DateTime @default(now())
  
  gridCell GridCell @relation(fields: [gridCellId], references: [id])
}

model PollutionSource {
  id          Int      @id @default(autoincrement())
  type        String
  description String?
  latitude    Float
  longitude   Float
  gridCellId  String
  createdAt   DateTime @default(now())
}